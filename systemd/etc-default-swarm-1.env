# 长机 sysid=1 默认环境（供 /etc/systemd/system/swarm-controller@1.service 读取）
# 长机视角：自己监听机间端口，主动向 GCS 上报；不需要 LEADER_IP（自己就是长机）
ROLE=1
GCS_HOST=10.8.0.100
GCS_PORT=14550
LEADER_IP=10.8.0.1
LINK_PORT=19870
CTRL_HZ=10
GCS_TX_KBPS=384
GCS_HB_HZ=1
HEALTH_WARN_MS=3000
HEALTH_LOST_MS=8000
DEGRADE_LOST=loiter

# 额外参数：
#   --followers 2,3          告知长机管哪几架僚机
#   --p900-uart9-fallback    弱信号外场启用 P900 兜底（需提前接好 P900 串口）
#   --gcs-udp-bind 10.8.0.1:14551  显式绑定到 wg0，避免被运营商 NAT 改源
EXTRA_ARGS=--followers 2,3 --gcs-udp-bind 10.8.0.1:14551
